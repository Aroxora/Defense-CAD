rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Contract requests - anyone can create, only admin can read/update
    match /contract_requests/{requestId} {
      allow create: if true;
      allow read, update, delete: if false; // Admin via console only
    }

    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
